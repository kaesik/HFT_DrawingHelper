<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Resources/MainWindowStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══ HFT TextBox: ControlBgBrush, CornerRadius 4, AccentColor focus ═══ -->
    <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background"               Value="{DynamicResource ControlBgBrush}"/>
        <Setter Property="Foreground"               Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource BorderColorBrush}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="10,0"/>
        <Setter Property="FontFamily"               Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize"                 Value="12"/>
        <Setter Property="CaretBrush"               Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="SelectionBrush"           Value="{DynamicResource AccentColorBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource ControlHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource AccentColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Grid x:Key="SettingsSidePanelContent"
          x:Shared="False"
          Width="260"
          Margin="14,10,14,14">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Panel header — tekst aktualizowany z code-behind ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SettingsPanelHeaderText"
                       Grid.Column="0"
                       Text="USTAWIENIA"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    x:Name="CloseSettingsPanelButton"
                    Style="{DynamicResource IconButton}"
                    Content="&#xE8BB;"
                    Width="28"
                    Height="28"
                    FontSize="11"
                    ToolTip="Zamknij panel"/>
        </Grid>

        <!-- ═══ TabControl (indeks synchronizowany z MainTabs z code-behind) ═══ -->
        <TabControl x:Name="SettingsTabs"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    SelectedIndex="1">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ─── 0: Krawędzie — brak ustawień ─── -->
            <TabItem Header="Krawędzie">
                <Border Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE783;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Brak ustawień dla tego modułu."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ─── 1: Przekroje ─── -->
            <TabItem Header="Przekroje">
                <Border Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="12">
                        <StackPanel>

                            <!-- Section: Atrybuty -->
                            <TextBlock Text="ATRYBUTY"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="ViewAttributeName"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="ViewAttributeNameComboBox"
                                      Style="{DynamicResource SettingsComboBoxStyle}"
                                      Height="32"
                                      Margin="0,0,0,10"
                                      FontSize="12"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True"/>

                            <TextBlock Text="MarkAttributeName"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="MarkAttributeNameComboBox"
                                      Style="{DynamicResource SettingsComboBoxStyle}"
                                      Height="32"
                                      Margin="0,0,0,0"
                                      FontSize="12"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True"/>

                            <Border Height="1"
                                    Background="{DynamicResource DividerColorBrush}"
                                    Margin="0,14,0,14"/>

                            <!-- Section: Parametry -->
                            <TextBlock Text="PARAMETRY"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="DepthUp"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="DepthUpTextBox"
                                     Style="{StaticResource SettingsTextBoxStyle}"
                                     Height="32"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="DepthDown"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="DepthDownTextBox"
                                     Style="{StaticResource SettingsTextBoxStyle}"
                                     Height="32"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="SectionLineLengthMillimeters"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="SectionLineLengthMillimetersTextBox"
                                     Style="{StaticResource SettingsTextBoxStyle}"
                                     Height="32"
                                     Margin="0,0,0,0"/>

                            <Border Height="1"
                                    Background="{DynamicResource DividerColorBrush}"
                                    Margin="0,14,0,14"/>

                            <!-- Actions -->
                            <Button x:Name="ApplySectionSettingsButton"
                                    Style="{DynamicResource PrimaryButton}"
                                    Content="Zapisz ustawienia"
                                    HorizontalAlignment="Stretch"
                                    Height="32"
                                    Margin="0,0,0,8"/>

                            <Button x:Name="ResetSectionSettingsButton"
                                    Style="{DynamicResource SecondaryButton}"
                                    Content="Resetuj do domyślnych"
                                    HorizontalAlignment="Stretch"
                                    Height="32"
                                    Margin="0,0,0,8"/>

                            <Button x:Name="RefreshSectionSettingsButton"
                                    Style="{DynamicResource SecondaryButton}"
                                    Content="Odśwież listę"
                                    HorizontalAlignment="Stretch"
                                    Height="32"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ─── 2: Wymiarowanie ─── -->
            <TabItem Header="Wymiarowanie">
                <Border Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="12">
                        <StackPanel>

                            <TextBlock Text="ATRYBUTY"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="DimensionAttributeName"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="DimensionAttributeNameComboBox"
                                      Style="{DynamicResource SettingsComboBoxStyle}"
                                      Height="32"
                                      Margin="0,0,0,0"
                                      FontSize="12"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True"/>

                            <Border Height="1"
                                    Background="{DynamicResource DividerColorBrush}"
                                    Margin="0,14,0,14"/>

                            <Button x:Name="ApplyDimensionSettingsButton"
                                    Style="{DynamicResource PrimaryButton}"
                                    Content="Zapisz ustawienia"
                                    HorizontalAlignment="Stretch"
                                    Height="32"
                                    Margin="0,0,0,8"/>

                            <Button x:Name="ResetDimensionSettingsButton"
                                    Style="{DynamicResource SecondaryButton}"
                                    Content="Resetuj do domyślnych"
                                    HorizontalAlignment="Stretch"
                                    Height="32"
                                    Margin="0,0,0,8"/>

                            <Button x:Name="RefreshDimensionSettingsButton"
                                    Style="{DynamicResource SecondaryButton}"
                                    Content="Odśwież listę"
                                    HorizontalAlignment="Stretch"
                                    Height="32"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ─── 3: Widok — brak ustawień ─── -->
            <TabItem Header="Widok">
                <Border Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE783;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Brak ustawień dla tego modułu."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ─── 4: Marki — brak ustawień ─── -->
            <TabItem Header="Marki">
                <Border Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE783;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Brak ustawień dla tego modułu."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</ResourceDictionary>
