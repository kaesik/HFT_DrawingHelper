<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderColorBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="WindowBorderBrushBrush" Color="#D0D0D0" />
    <SolidColorBrush x:Key="DividerColorBrush" Color="#E5E5E5" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentColorBrush" Color="#005FB8" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#003D7A" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5E5E5E" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9E9E9E" />
    <SolidColorBrush x:Key="ValueHighlightBrush" Color="#005FB8" />

    <!-- Controls -->
    <SolidColorBrush x:Key="ControlBgBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#EBEBEB" />

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#C42B1C" />

</ResourceDictionary>