<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Resources/MainWindowStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <StackPanel x:Key="ViewTabContent" x:Shared="False" Margin="0,12,0,0">
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Obrót"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       Text="Wskaż dwa punkty w widoku rysunku."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Kierunek"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       Text="Punkt bazowy → drugi punkt"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Plugin"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />

            <CheckBox x:Name="RunRubberbandDrawingPluginCheckBox"
                      Grid.Column="1"
                      Content="Uruchom RubberbandDrawing"

                      Style="{DynamicResource HftCheckBox}"
                      VerticalAlignment="Center"
                      ToolTip="Po obróceniu widoku uruchamia plugin RubberbandDrawing." />
        </Grid>

        <Button x:Name="RotateViewByTwoPointsButton"
                Content="Obróć widok"
                Style="{DynamicResource PrimaryButton}"
                HorizontalAlignment="Stretch"
                Height="32" />
    </StackPanel>
</ResourceDictionary>