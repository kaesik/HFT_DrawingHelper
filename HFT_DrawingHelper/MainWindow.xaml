<Window x:Class="HFT_DrawingHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="525">

    <Window.Resources>
        <!-- Placeholder dla SectionTextBox -->
        <Style x:Key="WatermarkSectionTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>

                            <!-- standardowy wygląd textboxa -->
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" />
                            </Border>

                            <!-- watermark -->
                            <TextBlock x:Name="Watermark"
                                       Text="Wpisz numery krawędzi (np. 1,3-5)"
                                       Foreground="Gray"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <!-- Placeholder dla DimensionTextBox -->
        <Style x:Key="WatermarkDimensionsTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>

                            <!-- standardowy wygląd textboxa -->
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" />
                            </Border>

                            <!-- watermark -->
                            <TextBlock x:Name="Watermark"
                                       Text="Wpisz Name lub ASSEMBLY_POS"
                                       Foreground="Gray"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Button: Rysuj linie + numerację -->
        <Button x:Name="DrawEdgesButton"
                Content="Rysuj krawędzie"
                Width="150"
                Height="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="350,150,0,0"
                Click="DrawEdgesButton_Click" />

        <!-- Label -->
        <Label x:Name="ModelDrawingLabel"
               Content="Label"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Width="450"
               Height="25"
               Margin="10,200,0,0" />

        <!-- PRZEKROJE -->
        <!-- TextBox: gdzie przekroje -->
        <TextBox x:Name="EdgeNumbersTextBox"
                 Style="{StaticResource WatermarkSectionTextBoxStyle}"
                 Width="300"
                 Height="40"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="10,50,0,0" />

        <!-- Button: Dodaj przekroje -->
        <Button x:Name="AddSectionsButton"
                Content="Dodaj przekroje"
                Width="150"
                Height="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="350,55,0,0"
                Click="AddSectionsButton_Click" />

        <!-- WYMIAROWANIE -->
        <!-- TextBox: co zwymiarować -->
        <TextBox x:Name="ElementsToDimensionTextBox"
                 Style="{StaticResource WatermarkDimensionsTextBoxStyle}"
                 Width="300"
                 Height="40"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="10,100,0,0" />

        <!-- Button: Dodaj wymiar -->
        <Button x:Name="AddDimensionsButton"
                Content="Dodaj wymiary"
                Width="150"
                Height="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="350,105,0,0"
                Click="AddDimensionsButton_Click" />
    </Grid>
</Window>