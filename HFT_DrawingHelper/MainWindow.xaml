<Window x:Class="HFT_DrawingHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HFT Drawing Helper"
        Width="420"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="Segoe UI Variable, Segoe UI">

    <!-- ═══════════════════════════════════════════════════
         Window chrome — drop shadow + rounded border
    ════════════════════════════════════════════════════ -->
    <Border Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrushBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3"
                              Opacity="0.45" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="36" />
                <!-- Content -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════
                 Title Bar
            ════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBgBrush}"
                    CornerRadius="7,7,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <!-- Logo area -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Title -->
                        <ColumnDefinition Width="*" />
                        <!-- Action buttons -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo (theme-tinted via OpacityMask) — Assets/logo.png must have Build Action = Resource -->
                    <Rectangle Grid.Column="1"
                               Width="32" Height="32"
                               Fill="{DynamicResource TextPrimaryBrush}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="pack://application:,,,/Assets/logo.png" Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <!-- App title -->
                    <TextBlock Grid.Column="2"
                               Text="DRAWING HELPER"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />

                    <!-- Theme toggle + Close -->
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button x:Name="ThemeToggleButton"
                                Style="{StaticResource IconButton}"
                                Content="&#xE793;"
                                ToolTip="Toggle theme"
                                Click="ThemeToggle_Click" />
                        <Button x:Name="CloseButton"
                                Style="{StaticResource CloseButton}"
                                Content="&#xE8BB;"
                                ToolTip="Close"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════
                 Content
            ════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1" Margin="14,10,14,14">

                <!-- ─── KRAWĘDZIE ─────────────────────── -->
                <TextBlock Text="KRAWĘDZIE"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />

                <Button x:Name="DrawEdgesButton"
                        Content="Rysuj krawędzie"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Height="32"
                        Click="DrawEdgesButton_Click" />

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,14,0,14" />

                <!-- ─── PRZEKROJE ─────────────────────── -->
                <TextBlock Text="PRZEKROJE"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />

                <TextBox x:Name="EdgeNumbersTextBox"
                         Style="{StaticResource HftTextBox}"
                         Tag="Numery krawędzi (np. 1,3-5)"
                         Height="34"
                         HorizontalAlignment="Stretch"
                         Margin="0,0,0,8" />

                <Button x:Name="AddSectionsButton"
                        Content="Dodaj przekroje"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Height="32"
                        Click="AddSectionsButton_Click" />

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,14,0,14" />

                <!-- ─── WYMIAROWANIE ──────────────────── -->
                <TextBlock Text="WYMIAROWANIE"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />

                <TextBox x:Name="ElementsToDimensionTextBox"
                         Style="{StaticResource HftTextBox}"
                         Tag="Name lub ASSEMBLY_POS"
                         Height="34"
                         HorizontalAlignment="Stretch"
                         Margin="0,0,0,10" />

                <!-- Row: Typ wymiaru -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Typ"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="CurvedDimensionRadioButton"
                                     Grid.Column="0"
                                     Content="Łukowy"
                                     Style="{StaticResource HftRadioButton}"
                                     IsChecked="True" />
                        <RadioButton Grid.Column="1"
                                     Content="Prostoliniowy"
                                     Style="{StaticResource HftRadioButton}" />
                    </Grid>
                </Grid>

                <!-- Row: Umiejscowienie H -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Poziom"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="DimensionAboveRadioButton"
                                     Grid.Column="0"
                                     Content="Powyżej"
                                     Style="{StaticResource HftRadioButton}"
                                     GroupName="HPlacement"
                                     IsChecked="True" />
                        <RadioButton Grid.Column="1"
                                     Content="Poniżej"
                                     Style="{StaticResource HftRadioButton}"
                                     GroupName="HPlacement" />
                    </Grid>
                </Grid>

                <!-- Row: Umiejscowienie V -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Pion"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="DimensionRightRadioButton"
                                     Grid.Column="0"
                                     Content="Prawa"
                                     Style="{StaticResource HftRadioButton}"
                                     GroupName="VPlacement"
                                     IsChecked="True" />
                        <RadioButton Grid.Column="1"
                                     Content="Lewa"
                                     Style="{StaticResource HftRadioButton}"
                                     GroupName="VPlacement" />
                    </Grid>
                </Grid>

                <!-- Row: Co tworzyć -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Utwórz"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="HorizontalDimensionCheckBox"
                                  Grid.Column="0"
                                  Content="Poziomy"
                                  Style="{StaticResource HftCheckBox}"
                                  IsChecked="True" />
                        <CheckBox x:Name="VerticalDimensionCheckBox"
                                  Grid.Column="1"
                                  Content="Pionowy"
                                  Style="{StaticResource HftCheckBox}"
                                  IsChecked="True" />
                    </Grid>
                </Grid>

                <Button x:Name="AddDimensionsButton"
                        Content="Dodaj wymiary"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Height="32"
                        Click="AddDimensionsButton_Click" />

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,14,0,10" />

                <!-- ─── Status Bar ─────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Model:"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <TextBlock x:Name="ModelDrawingLabel"
                               Grid.Column="1"
                               Foreground="{DynamicResource ValueHighlightBrush}"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>