<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#1C1C1C" />
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#383838" />
    <SolidColorBrush x:Key="CardBgBrush" Color="#323232" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderColorBrush" Color="#404040" />
    <SolidColorBrush x:Key="WindowBorderBrushBrush" Color="#333333" />
    <SolidColorBrush x:Key="DividerColorBrush" Color="#3D3D3D" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentColorBrush" Color="#60CDFF" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#0093CC" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9E9E9E" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#6E6E6E" />
    <SolidColorBrush x:Key="ValueHighlightBrush" Color="#60CDFF" />

    <!-- Controls -->
    <SolidColorBrush x:Key="ControlBgBrush" Color="#3A3A3A" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#454545" />

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="#1C1C1C" />
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#C42B1C" />

</ResourceDictionary>