<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Resources/MainWindowStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Grid x:Key="SettingsSidePanelContent" x:Shared="False" Width="260"
                          Margin="14,10,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="USTAWIENIA ATRYBUTÓW"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"
                                    Style="{DynamicResource IconButton}"
                                    Content="&#xE8BB;"
                                    Width="22"
                                    Height="22"
                                    FontSize="10"
                                    ToolTip="Zamknij panel" x:Name="CloseSettingsPanelButton" />
                        </Grid>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="ViewAttributeName"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />

                            <ComboBox x:Name="ViewAttributeNameComboBox"
                                      Style="{DynamicResource SettingsComboBoxStyle}"
                                      Height="32"
                                      Margin="0,0,0,10"
                                      FontSize="12"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True" />

                            <TextBlock Text="MarkAttributeName"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />

                            <ComboBox x:Name="MarkAttributeNameComboBox"
                                      Style="{DynamicResource SettingsComboBoxStyle}"
                                      Height="32"
                                      Margin="0,0,0,10"
                                      FontSize="12"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True" />

                            <TextBlock Text="DimensionAttributeName"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />

                            <ComboBox x:Name="DimensionAttributeNameComboBox"
                                      Style="{DynamicResource SettingsComboBoxStyle}"
                                      Height="32"
                                      Margin="0,0,0,12"
                                      FontSize="12"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True" />

                            <Button x:Name="RefreshSectionSettingsButton"
                                    Style="{DynamicResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Height="32"
                                    Margin="0,0,0,8">
                                <Button.Triggers>
                                    <EventTrigger RoutedEvent="Button.Click">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!-- Ukryj tekst -->
                                                <DoubleAnimation Storyboard.TargetName="RefreshText"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0"
                                                                 Duration="0:0:0.12" />
                                                <!-- Pokaż ikonę -->
                                                <DoubleAnimation Storyboard.TargetName="RefreshIcon"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1"
                                                                 Duration="0:0:0.12"
                                                                 BeginTime="0:0:0.12" />
                                                <!-- Obrót 360° -->
                                                <DoubleAnimation Storyboard.TargetName="RefreshRotate"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360"
                                                                 Duration="0:0:0.65"
                                                                 BeginTime="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <!-- Ukryj ikonę -->
                                                <DoubleAnimation Storyboard.TargetName="RefreshIcon"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0"
                                                                 Duration="0:0:0.12"
                                                                 BeginTime="0:0:0.77" />
                                                <!-- Przywróć tekst -->
                                                <DoubleAnimation Storyboard.TargetName="RefreshText"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1"
                                                                 Duration="0:0:0.12"
                                                                 BeginTime="0:0:0.89" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Button.Triggers>
                                <Grid>
                                    <TextBlock x:Name="RefreshText"
                                               Text="Odśwież listę"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="RefreshIcon"
                                               Text="&#xE72C;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15"
                                               Opacity="0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="RefreshRotate" Angle="0" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Grid>
                            </Button>

                            <Button x:Name="ApplySectionSettingsButton"
                                    Style="{DynamicResource PrimaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Height="32">
                                <Button.Triggers>
                                    <EventTrigger RoutedEvent="Button.Click">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!-- Ukryj tekst -->
                                                <DoubleAnimation Storyboard.TargetName="ApplyText"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0"
                                                                 Duration="0:0:0.12" />
                                                <!-- Pokaż ptaszka -->
                                                <DoubleAnimation Storyboard.TargetName="ApplyCheck"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1"
                                                                 Duration="0:0:0.15"
                                                                 BeginTime="0:0:0.12" />
                                                <!-- Lekkie powiększenie ptaszka -->
                                                <DoubleAnimation Storyboard.TargetName="ApplyCheckScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 From="0.5" To="1"
                                                                 Duration="0:0:0.2"
                                                                 BeginTime="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction>
                                                        <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ApplyCheckScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 From="0.5" To="1"
                                                                 Duration="0:0:0.2"
                                                                 BeginTime="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction>
                                                        <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <!-- Ukryj ptaszka -->
                                                <DoubleAnimation Storyboard.TargetName="ApplyCheck"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0"
                                                                 Duration="0:0:0.15"
                                                                 BeginTime="0:0:1.1" />
                                                <!-- Przywróć tekst -->
                                                <DoubleAnimation Storyboard.TargetName="ApplyText"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1"
                                                                 Duration="0:0:0.15"
                                                                 BeginTime="0:0:1.25" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Button.Triggers>
                                <Grid>
                                    <TextBlock x:Name="ApplyText"
                                               Text="Zastosuj"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="ApplyCheck"
                                               Text="&#xE73E;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15"
                                               Foreground="#4CAF50"
                                               Opacity="0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform x:Name="ApplyCheckScale"
                                                            ScaleX="1" ScaleY="1" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
</ResourceDictionary>
