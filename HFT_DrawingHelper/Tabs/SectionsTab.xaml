<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Resources/MainWindowStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <StackPanel x:Key="SectionsTabContent" x:Shared="False" Margin="0,12,0,0">
        <TextBlock Text="Tworzenie przekrojów z zaznaczonych krawędzi z prawego panelu."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <Button x:Name="AddSectionsButton"
                Content="Dodaj przekroje"
                Style="{DynamicResource PrimaryButton}"
                HorizontalAlignment="Stretch"
                Height="32" />
    </StackPanel>
</ResourceDictionary>
