<Window x:Class="HFT_DrawingHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HFT Drawing Helper"
        Height="310" Width="525"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" />
                            </Border>
                            <TextBlock x:Name="Watermark"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="Gray"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="10,10,10,10" VerticalAlignment="Top">

        <Label x:Name="ModelDrawingLabel"
               Content="Label"
               Padding="0,0,0,4" />

        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <TextBox x:Name="EdgeNumbersTextBox"
                     Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                     Style="{StaticResource WatermarkTextBoxStyle}"
                     Tag="Wpisz numery krawędzi (np. 1,3-5)"
                     VerticalAlignment="Stretch" />

            <Button x:Name="DrawEdgesButton"
                    Grid.Column="2" Grid.Row="0"
                    Content="Rysuj krawędzie"
                    Click="DrawEdgesButton_Click" />

            <Button x:Name="AddSectionsButton"
                    Grid.Column="2" Grid.Row="2"
                    Content="Dodaj przekroje"
                    Click="AddSectionsButton_Click" />
        </Grid>

        <Separator Margin="0,10,0,10" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="ElementsToDimensionTextBox"
                     Grid.Column="0"
                     Style="{StaticResource WatermarkTextBoxStyle}"
                     Tag="Wpisz Name lub ASSEMBLY_POS"
                     Height="30" />

            <Button x:Name="AddDimensionsButton"
                    Grid.Column="2"
                    Content="Dodaj wymiary"
                    Height="30"
                    Click="AddDimensionsButton_Click" />
        </Grid>

        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="24" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0"
                   Content="Typ:"
                   VerticalAlignment="Center" Padding="0" />

            <RadioButton x:Name="StraightDimensionRadioButton"
                         Grid.Column="1" Grid.Row="0"
                         Content="Prostoliniowy"
                         GroupName="DimensionType"
                         IsChecked="True"
                         VerticalAlignment="Center" />

            <RadioButton x:Name="CurvedDimensionRadioButton"
                         Grid.Column="2" Grid.Row="0"
                         Content="Zakrzywiony"
                         GroupName="DimensionType"
                         VerticalAlignment="Center" />

            <CheckBox x:Name="HorizontalDimensionCheckBox"
                      Grid.Column="0" Grid.Row="1"
                      Content="Poziomy"
                      IsChecked="True"
                      VerticalAlignment="Center" />

            <RadioButton x:Name="DimensionBelowRadioButton"
                         Grid.Column="1" Grid.Row="1"
                         Content="Dół"
                         GroupName="HorizontalDimensionPlacement"
                         IsChecked="True"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsChecked, ElementName=HorizontalDimensionCheckBox}" />

            <RadioButton x:Name="DimensionAboveRadioButton"
                         Grid.Column="2" Grid.Row="1"
                         Content="Góra"
                         GroupName="HorizontalDimensionPlacement"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsChecked, ElementName=HorizontalDimensionCheckBox}" />

            <CheckBox x:Name="VerticalDimensionCheckBox"
                      Grid.Column="0" Grid.Row="2"
                      Content="Pionowy"
                      IsChecked="True"
                      VerticalAlignment="Center" />

            <RadioButton x:Name="DimensionLeftRadioButton"
                         Grid.Column="1" Grid.Row="2"
                         Content="Lewo"
                         GroupName="VerticalDimensionPlacement"
                         IsChecked="True"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsChecked, ElementName=VerticalDimensionCheckBox}" />

            <RadioButton x:Name="DimensionRightRadioButton"
                         Grid.Column="2" Grid.Row="2"
                         Content="Prawo"
                         GroupName="VerticalDimensionPlacement"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsChecked, ElementName=VerticalDimensionCheckBox}" />
        </Grid>

    </StackPanel>
</Window>