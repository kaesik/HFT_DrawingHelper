<Window x:Class="HFT_DrawingHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HFT Drawing Helper"
        MinWidth="420"
        MinHeight="320"
        SizeToContent="WidthAndHeight"
        MaxHeight="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindowStyles.xaml" />
                <ResourceDictionary Source="Tabs/EdgesTab.xaml" />
                <ResourceDictionary Source="Tabs/SectionsTab.xaml" />
                <ResourceDictionary Source="Tabs/DimensionsTab.xaml" />
                <ResourceDictionary Source="SidePanels/SettingsSidePanel.xaml" />
                <ResourceDictionary Source="SidePanels/PartsSidePanel.xaml" />
                <ResourceDictionary Source="SidePanels/EdgesSidePanel.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ══════════════════════════════════════════
                 HFT-style TabItem — flat pill z podkreśleniem
                 ══════════════════════════════════════════ -->
            <Style x:Key="HftTabItem" TargetType="TabItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="Height" Value="32" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid x:Name="Root">
                                <!-- pill hover -->
                                <Border x:Name="Pill"
                                        Background="Transparent"
                                        CornerRadius="4"
                                        Margin="0,4,0,4" />

                                <!-- etykieta -->
                                <ContentPresenter x:Name="Label"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"
                                                  TextElement.FontWeight="Regular" />

                                <!-- akcent — dolna kreska -->
                                <Border x:Name="Accent"
                                        Height="2"
                                        CornerRadius="1"
                                        Background="{DynamicResource AccentColorBrush}"
                                        VerticalAlignment="Bottom"
                                        Margin="10,0,10,0"
                                        Opacity="0" />
                            </Grid>

                            <ControlTemplate.Triggers>
                                <!-- hover (niezaznaczony) -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsSelected" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Pill" Property="Background"
                                            Value="{DynamicResource SurfaceHoverBrush}" />
                                    <Setter TargetName="Label" Property="TextElement.Foreground"
                                            Value="{DynamicResource TextPrimaryBrush}" />
                                </MultiTrigger>

                                <!-- wybrany -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Accent" Property="Opacity" Value="1" />
                                    <Setter TargetName="Label" Property="TextElement.Foreground"
                                            Value="{DynamicResource AccentColorBrush}" />
                                    <Setter TargetName="Label" Property="TextElement.FontWeight"
                                            Value="SemiBold" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TabControl — usuwa domyślne tło i obramowania -->
            <Style x:Key="HftTabControl" TargetType="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- pasek zakładek -->
                                <Border Grid.Row="0"
                                        BorderBrush="{DynamicResource DividerColorBrush}"
                                        BorderThickness="0,0,0,1">
                                    <TabPanel x:Name="HeaderPanel"
                                              IsItemsHost="True"
                                              Background="Transparent"
                                              Margin="0,0,0,0" />
                                </Border>

                                <!-- zawartość aktywnej zakładki + ekran startowy -->
                                <Grid Grid.Row="1">
                                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                                      ContentSource="SelectedContent" />

                                    <!-- ══ EKRAN STARTOWY ══
                                         Widoczny do momentu pierwszego wyboru zakładki.
                                         Ukrywany z code-behind przez FindNamedDescendant("StartScreen"). -->
                                    <Border x:Name="StartScreen"
                                            Panel.ZIndex="10"
                                            Background="{DynamicResource WindowBgBrush}"
                                            MinHeight="185"
                                            Visibility="Visible">
                                        <StackPanel VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,28,0,28">

                                            <!-- Logo w kolorze akcentu -->
                                            <Rectangle Width="46" Height="46"
                                                       HorizontalAlignment="Center"
                                                       Fill="{DynamicResource AccentColorBrush}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Margin="0,0,0,14">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="pack://application:,,,/Assets/logo.png"
                                                                Stretch="Uniform" />
                                                </Rectangle.OpacityMask>
                                            </Rectangle>

                                            <!-- Nazwa programu -->
                                            <TextBlock Text="DRAWING HELPER"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,3" />

                                            <!-- Branding HFT -->
                                            <TextBlock Text="HOLDFORT S.A."
                                                       Foreground="{DynamicResource AccentColorBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,18" />

                                            <!-- Separator -->
                                            <Border Height="1" Width="180"
                                                    Background="{DynamicResource DividerColorBrush}"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,0,14" />

                                            <!-- Podpowiedź -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE76C;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="9"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0" />
                                                <TextBlock Text="Wybierz zakładkę, aby rozpocząć"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrushBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12"
                              ShadowDepth="2"
                              Opacity="0.4"
                              Color="#000000" />
        </Border.Effect>

        <Grid x:Name="RootLayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Border Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Background="{DynamicResource TitleBarBgBrush}"
                    CornerRadius="7,7,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="1"
                               Width="32"
                               Height="32"
                               Fill="{DynamicResource TextPrimaryBrush}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="pack://application:,,,/Assets/logo.png"
                                        Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <TextBlock Grid.Column="2"
                               Text="DRAWING HELPER"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button x:Name="SettingsToggleButton"
                                Style="{StaticResource IconButton}"
                                Content="&#xE713;"
                                ToolTip="Ustawienia przekrojów"
                                Click="SettingsToggleButton_Click" />
                        <Button x:Name="ThemeToggleButton"
                                Style="{StaticResource IconButton}"
                                Content="&#xE793;"
                                ToolTip="Toggle theme"
                                Click="ThemeToggle_Click" />
                        <Button x:Name="CloseButton"
                                Style="{StaticResource CloseButton}"
                                Content="&#xE8BB;"
                                ToolTip="Close"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Left side panel (settings) ── -->
            <Border x:Name="SettingsPanelBorder"
                    Grid.Row="1"
                    Grid.Column="0"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource DividerColorBrush}"
                    BorderThickness="0,0,1,0">
                <ContentControl Content="{StaticResource SettingsSidePanelContent}" />
            </Border>

            <!-- ── Main content ── -->
            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Margin="14,10,14,14">

                <!-- TabControl z HFT-style zakładkami -->
                <TabControl x:Name="MainTabs"
                            Style="{StaticResource HftTabControl}"
                            SelectionChanged="MainTabs_SelectionChanged">
                    <TabItem Header="Krawędzie"
                             Style="{StaticResource HftTabItem}">
                        <ContentControl Content="{StaticResource EdgesTabContent}" />
                    </TabItem>
                    <TabItem Header="Przekroje"
                             Style="{StaticResource HftTabItem}">
                        <ContentControl Content="{StaticResource SectionsTabContent}" />
                    </TabItem>
                    <TabItem Header="Wymiarowanie"
                             Style="{StaticResource HftTabItem}">
                        <ContentControl Content="{StaticResource DimensionsTabContent}" />
                    </TabItem>
                </TabControl>

                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,14,0,10" />

                <!-- Model row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="MODEL:"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <TextBlock x:Name="ModelDrawingLabel"
                               Grid.Column="1"
                               Foreground="{DynamicResource ValueHighlightBrush}"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </StackPanel>

            <!-- ── Right side panel ── -->
            <Border x:Name="SidePanelBorder"
                    Grid.Row="1"
                    Grid.Column="2"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource DividerColorBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Width="260"
                      Margin="14,10,14,14">
                    <ContentControl x:Name="PartsSidePanelHost"
                                    Content="{StaticResource PartsSidePanelContent}" />
                    <ContentControl x:Name="EdgesSidePanelHost"
                                    Content="{StaticResource EdgesSidePanelContent}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>